#hxeqdata41
C+O2#充足=CO2#点燃
2C+O2#不足=2CO#点燃
3Fe+2O2=Fe3O4#点燃
2NaHCO3=Na2CO3+H2O+CO2#↑△
2Na+Cl2=2NaCl
2CuO+C=2Cu+CO2#高温
Fe2O3+3CO=2Fe+3CO2#高温
Fe+CuSO4=FeSO4#绿+Cu
S+Fe=FeS#△
S+2Cu=Cu2S#△
S+H2=H2S#△
S+O2=SO2#点燃
2SO2+O2-2SO3#催化剂,△
SO2+2H2S=3S#黄+2H2O
CO2+C=2CO#高温
SO2+H2O-H2SO3#SO2形成酸雨
CO2+H2O-H2SO3#CO2引起温室效应
Cl2+SO2+2H2O=H2SO4+2HCl#卤素单质Cl,Br,I
SO3+H2O=H2SO4#(△)
SO2+NaOH#少量=NaHSO3#SO2~OH⁻→HSO3⁻
SO2+2NaOH#足量=Na2SO3+H2O#SO2~2OH⁻→SO3²⁻~H2O
SO2+CaO=CaSO3#灰白
SO3+CaO=CaSO4#灰白
SO2#少量+Ca(OH)2=CaSO3#灰白↓+H2O
CO2#少量+Ca(OH)2=CaCO3#灰白↓+H2O
SO2#少量+2NaHCO3=NaSO3+H2O+CO2
SO2#足量+NaHCO3=NaHSO3+CO2
SO2+CaSO3+H2O=Ca(HSO3)2
CO2+CaCO3+H2O=Ca(HCO3)2
2SO2#大量+Ca(OH)2=Ca(HSO3)2#先沉淀后溶解
2CO2#大量+Ca(OH)2=Ca(HCO3)2#先沉淀后溶解
SO3+Ca(OH)2=CaSO4#灰白↓+H2O
Na2SO3+H2SO4#浓=Na2SO4+SO2#↑+H2O
2NaOH+SO2=Na2SO3+H2O
4FeS2+11O2=2Fe2O3+8SO2#高温
Cu+2H2SO4#浓=CuSO4#蓝+SO2#↑+2H2O#△
C+2H2SO4#浓=CO2#↑+2H2O+2SO2#↑△
MgCl2+Ba(OH)2=BaCl2+Mg(OH)2#灰白↓
MgSO4+Ba(OH)2=BaSO4#白↓+Mg(OH)2#↓
Ba(OH)2+K2CO3=BaCO3#白↓+2KOH
BaCl2+K2CO3=BaCO3#白↓+2KCl