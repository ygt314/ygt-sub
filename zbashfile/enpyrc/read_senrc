r_s()
{
if [ -z $1 ];then
    echo "no filename"
else
    echo "+--start--"
    j=$(cat $enf/$1.s |wc -l)
    for k in $(seq 1 $j)
    do
        str=$(head -$k $enf/$1.s|tail -n 1)
        if [ "$a"x = "q"x ];then
            break
        elif [ "${str:0:6}"x = "#sleep"x ];then
            echo "$str";eval "${str:1}"
        else
            echo "File $1.s:$k"
            python $enf/read_txt.py $str
        fi
    done
    echo "+---end---"
fi
}